/* 新版 TabBar — 三段式胶囊导航 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12rpx 48rpx 24rpx;
  z-index: 999;
  pointer-events: none;
}

.tab-bar-pill {
  display: flex;
  align-items: center;
  height: 112rpx;
  padding: 8rpx;
  background: #F6F4EE;
  border: 1rpx solid #D5D0C8;
  border-radius: 56rpx;
  pointer-events: auto;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 48rpx;
  gap: 4rpx;
}

.tab-active {
  background: rgba(139, 166, 118, 0.12);
}

.tab-icon {
  width: 32rpx;
  height: 32rpx;
}

.tab-label {
  font-size: 18rpx;
  font-weight: 500;
  color: #A09A92;
  line-height: 1;
}

.tab-active .tab-label {
  color: #8BA676;
}

/* 中间封存按钮 */
.tab-seal {
  display: flex;
  align-items: center;
  justify-content: center;
}

.seal-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  border: 3rpx solid #3A3632;
  display: flex;
  align-items: center;
  justify-content: center;
}

.seal-icon {
  width: 40rpx;
  height: 40rpx;
}
