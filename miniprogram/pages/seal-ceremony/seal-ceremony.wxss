.page {
  position: relative;
  width: 100%;
  height: 100vh;
  background: #ECEAE2;
  overflow: hidden;
}

/* 便签 */
.sticky-note {
  position: absolute;
  left: 50%;
  top: 200rpx;
  transform: translateX(-50%) rotate(-5deg);
  width: 400rpx;
  height: 280rpx;
  background: #FFF9EE;
  border: 1rpx solid #E8D5B8;
  border-radius: 4rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.09), 0 4rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.8s ease-in;
  z-index: 10;
}

.sticky-note.shrink {
  top: 50%;
  transform: translateX(-50%) rotate(0deg) scale(0.1);
  opacity: 0;
}

.tape {
  position: absolute;
  top: -4rpx;
  left: 50%;
  transform: translateX(-50%) rotate(3deg);
  width: 80rpx;
  height: 28rpx;
  background: rgba(139, 166, 118, 0.4);
  border-radius: 4rpx;
}

.note-text {
  font-size: 22rpx;
  color: #5C4E42;
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.note-date {
  font-size: 18rpx;
  color: #B8A898;
  margin-top: 16rpx;
}

.ruled-line {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  height: 1rpx;
  background: #E8D5B8;
}

/* 幽灵便签 */
.ghost-note {
  position: absolute;
  left: 50%;
  background: #FFF9EE;
  border: 1rpx solid #E8D5B8;
  border-radius: 4rpx;
  transition: opacity 0.6s;
}

.ghost-1 {
  top: 520rpx;
  transform: translateX(-50%) rotate(-3deg);
  width: 280rpx;
  height: 200rpx;
}

.ghost-2 {
  top: 680rpx;
  transform: translateX(-50%) rotate(-3deg);
  width: 160rpx;
  height: 120rpx;
}

/* 轨迹粒子 */
.trail {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 50%;
  background: rgba(139, 166, 118, 0.3);
  transition: opacity 0.5s;
}

/* 胶囊 */
.capsule-area {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 240rpx;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 1s ease-in;
  z-index: 5;
}

.capsule-area.float-up {
  top: -100rpx;
  opacity: 0;
}

.capsule-glow {
  position: absolute;
  width: 240rpx;
  height: 240rpx;
  border-radius: 120rpx;
  background: radial-gradient(circle, rgba(139,166,118,0.19) 0%, transparent 70%);
}

.capsule-body {
  width: 128rpx;
  height: 192rpx;
  border-radius: 64rpx;
  background: linear-gradient(180deg, #D5E4C8 0%, #8BA676 50%, #6B8A58 100%);
  border: 3rpx solid rgba(139, 166, 118, 0.5);
  box-shadow: 0 40rpx 40rpx rgba(139,166,118,0.25), 0 -4rpx 16rpx rgba(255,255,255,0.19);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.capsule-slot {
  width: 80rpx;
  height: 8rpx;
  background: rgba(255,255,255,0.19);
  border-radius: 4rpx;
  position: absolute;
  top: 12rpx;
}

.capsule-center {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(255,255,255,0.25);
  background: rgba(255,255,255,0.15);
}

/* 光粒子 */
.spark {
  position: absolute;
  border-radius: 50%;
  transition: opacity 0.5s;
}

.spark-1 { width: 8rpx; height: 8rpx; background: rgba(139,166,118,0.31); top: 55%; left: 22%; animation: sparkle 2s infinite; }
.spark-2 { width: 6rpx; height: 6rpx; background: rgba(139,166,118,0.25); top: 58%; right: 22%; animation: sparkle 2s 0.5s infinite; }
.spark-3 { width: 10rpx; height: 10rpx; background: rgba(139,166,118,0.19); top: 65%; left: 28%; animation: sparkle 2s 1s infinite; }
.spark-4 { width: 6rpx; height: 6rpx; background: rgba(200,184,160,0.25); top: 62%; right: 28%; animation: sparkle 2s 1.5s infinite; }

@keyframes sparkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.5); }
}

/* 状态文字 */
.status-area {
  position: absolute;
  left: 0;
  right: 0;
  top: 72%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  transition: opacity 0.6s;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #8BA676;
  letter-spacing: 2rpx;
}

.status-sub {
  font-size: 24rpx;
  color: #B8A898;
}

.status-hint {
  position: absolute;
  bottom: 180rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 22rpx;
  color: #C5BFB6;
  transition: opacity 0.6s;
}
