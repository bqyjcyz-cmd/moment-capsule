.page {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background: #ECEAE2;
}

.status-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: transparent;
}

/* 标题栏 */
.title-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
  padding-top: var(--status-bar-height, 44px);
  height: calc(var(--status-bar-height, 44px) + 88rpx);
}

.title-icon {
  width: 40rpx;
  height: 40rpx;
}

.month-tag {
  display: inline-flex;
  padding: 8rpx 32rpx;
  background: rgba(139, 166, 118, 0.15);
  border-radius: 8rpx;
}

.month-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #8BA676;
  letter-spacing: 4rpx;
}

/* 地图 */
.map {
  width: 100%;
  height: 100%;
}

/* 空状态 */
.empty-state {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.empty-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  border: 1rpx solid rgba(213, 208, 200, 0.38);
  background: rgba(246, 244, 238, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-icon-img {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 24rpx;
  color: #A09A92;
  text-align: center;
}

/* 历史上的今天卡片 */
.today-card {
  position: fixed;
  top: calc(var(--status-bar-height, 44px) + 88rpx + 16rpx);
  left: 32rpx;
  right: 32rpx;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 24rpx;
  background: #F6F4EE;
  border: 1rpx solid #D5D0C8;
  border-radius: 8rpx;
  z-index: 200;
  opacity: 0;
  transform: translateY(-20rpx);
  transition: all 0.4s ease-out;
}

.today-card.show {
  opacity: 1;
  transform: translateY(0);
}

.today-photo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  overflow: hidden;
  flex-shrink: 0;
  border: 1rpx solid #D5D0C8;
}

.today-photo-img {
  width: 100%;
  height: 100%;
}

.today-photo-placeholder {
  width: 100%;
  height: 100%;
  background: #D8D4CB;
}

.today-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.today-label {
  font-size: 20rpx;
  font-weight: 500;
  color: #8BA676;
}

.today-content {
  font-size: 24rpx;
  color: #3A3632;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 定位按钮 */
.locate-btn {
  position: fixed;
  right: 32rpx;
  bottom: 280rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #F6F4EE;
  border: 1rpx solid #D5D0C8;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 50;
}

.locate-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 预览卡片 */
.preview-card {
  position: fixed;
  bottom: 220rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 24rpx;
  background: #F6F4EE;
  border: 1rpx solid #D5D0C8;
  border-radius: 8rpx;
  z-index: 150;
  opacity: 0;
  transform: translateY(40rpx);
  transition: all 0.3s ease-out;
}

.preview-card.show {
  opacity: 1;
  transform: translateY(0);
}

.preview-photo {
  width: 112rpx;
  height: 112rpx;
  border-radius: 8rpx;
  overflow: hidden;
  flex-shrink: 0;
  border: 1rpx solid #D5D0C8;
}

.preview-photo-img {
  width: 100%;
  height: 100%;
}

.preview-photo-placeholder {
  width: 100%;
  height: 100%;
  background: #D8D4CB;
}

.preview-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  overflow: hidden;
}

.preview-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #3A3632;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.preview-meta-text {
  font-size: 20rpx;
  color: #A09A92;
}
