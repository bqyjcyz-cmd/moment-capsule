.page {
  position: relative;
  width: 100%; height: 100vh;
  overflow: hidden;
  background: #1A1918;
}

/* 照片 swiper — z-index 最高，可接收左右滑动 */
.photo-swiper {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 3;
}

.photo-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 1;
}

.photo-bg-img { width: 100%; height: 100%; }

.gradient-bg {
  background: linear-gradient(180deg, #2A2A22 0%, #1A1918 60%);
}

/* 暗色蒙层 — pointer-events:none 不拦截触摸 */
.dark-overlay {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 4;
  pointer-events: none;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0) 0%,
    rgba(0, 0, 0, 0.04) 35%,
    rgba(0, 0, 0, 0.55) 65%,
    rgba(0, 0, 0, 0.85) 100%
  );
}

/* 导航栏 */
.nav-bar {
  position: absolute;
  top: 0; left: 0; right: 0;
  z-index: 10;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 32rpx; height: 88rpx;
}

.nav-btn {
  width: 64rpx; height: 64rpx; border-radius: 32rpx;
  background: rgba(0, 0, 0, 0.2);
  display: flex; align-items: center; justify-content: center;
}

.nav-btn-icon { width: 36rpx; height: 36rpx; opacity: 0.85; }
.nav-dots { font-size: 36rpx; color: rgba(255, 255, 255, 0.85); letter-spacing: 2rpx; }
.nav-spacer { flex: 1; }

/* ===== 内容信息面板 ===== */
/* pointer-events:none 让滑动穿透到 swiper，按钮单独恢复 */
.info-panel {
  position: absolute;
  left: 0; right: 0;
  z-index: 8;
  padding: 0 56rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  pointer-events: none;
}

/* 面板内可交互元素恢复点击 */
.info-audio, .text-scroll { pointer-events: auto; }

/* 文字滚动区 */
.text-scroll { box-sizing: border-box; margin-bottom: 8rpx; }

.review-text {
  font-size: 32rpx;
  color: #FFFFFF;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 统一信息条 — 心情+地点+时间+录音 */
.info-bar {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-mood {
  display: flex; align-items: center; gap: 12rpx;
}

.info-mood-emoji { font-size: 32rpx; line-height: 1; }
.info-mood-name { font-size: 22rpx; color: rgba(255, 255, 255, 0.6); }

.info-location { font-size: 24rpx; color: rgba(255, 255, 255, 0.5); }
.info-date { font-size: 24rpx; color: rgba(255, 255, 255, 0.35); }

/* 录音条 — 始终可见 */
.info-audio {
  display: flex; align-items: center; gap: 12rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  width: fit-content;
}

.info-audio-icon { font-size: 24rpx; color: rgba(255, 255, 255, 0.8); }
.info-audio-label { font-size: 22rpx; color: rgba(255, 255, 255, 0.6); }

.info-audio-wave { display: flex; align-items: center; gap: 4rpx; }

.wave-bar-sm {
  width: 4rpx; height: 16rpx; border-radius: 2rpx;
  background: rgba(255, 255, 255, 0.4);
  animation: waveSm 0.6s ease-in-out infinite alternate;
}

.wave-bar-sm:nth-child(2) { height: 24rpx; animation-delay: 0.1s; }
.wave-bar-sm:nth-child(3) { height: 20rpx; animation-delay: 0.2s; }
.wave-bar-sm:nth-child(4) { height: 28rpx; animation-delay: 0.3s; }
.wave-bar-sm:nth-child(5) { height: 14rpx; animation-delay: 0.4s; }

@keyframes waveSm {
  from { opacity: 0.3; transform: scaleY(0.6); }
  to { opacity: 0.8; transform: scaleY(1); }
}

/* 图片指示器 — 屏幕最底部独立区域 */
.photo-dots-bar {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  z-index: 9;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 0;
}

.photo-counter {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  font-variant-numeric: tabular-nums;
}

.photo-dots { display: flex; justify-content: center; gap: 10rpx; }

.dot {
  width: 10rpx; height: 10rpx; border-radius: 5rpx;
  background: rgba(255, 255, 255, 0.25); transition: all 0.3s;
}

.dot-active { width: 24rpx; background: rgba(255, 255, 255, 0.75); }

/* 菜单 */
.menu-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100; background: rgba(0, 0, 0, 0.4);
  opacity: 0; transition: opacity 0.2s;
}

.menu-overlay.show { opacity: 1; }

.menu-sheet {
  position: fixed; left: 0; right: 0; bottom: 0;
  z-index: 101; background: #F6F4EE;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom, 0);
  transform: translateY(100%); transition: transform 0.25s ease-out;
}

.menu-sheet.show { transform: translateY(0); }

.menu-handle { width: 56rpx; height: 6rpx; border-radius: 3rpx; background: #D5D0C8; margin: 16rpx auto 8rpx; }

.menu-item {
  display: flex; align-items: center; justify-content: center;
  height: 108rpx; font-size: 30rpx; color: #3A3632;
  border-bottom: 1rpx solid #E8E4DC;
}

.menu-item:active { background: #ECEAE2; }
.menu-item-danger { color: #C47070; }

.menu-divider {
  height: 12rpx; background: #ECEAE2;
  border-top: 1rpx solid #D5D0C8; border-bottom: 1rpx solid #D5D0C8;
}

.menu-item-cancel { color: #A09A92; border-bottom: none; }
