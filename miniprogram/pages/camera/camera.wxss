.page {
  height: 100vh;
  background: #1A1816;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.status-bar { flex-shrink: 0; }

/* 顶部栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
  height: 88rpx;
  flex-shrink: 0;
}

.top-icon { width: 48rpx; height: 48rpx; }

.hdr-label {
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.5);
}

/* 取景框 */
.viewfinder {
  flex: 1;
  margin: 0 16rpx;
  border-radius: 32rpx;
  overflow: hidden;
}

.camera-view { width: 100%; height: 100%; }

.camera-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  background: #000;
}

.camera-placeholder-text { color: rgba(255,255,255,0.4); font-size: 28rpx; }

/* 模式栏 */
.mode-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
  height: 80rpx;
  flex-shrink: 0;
}

.mode-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.38);
}

.mode-active {
  color: #FFFFFF;
  font-weight: 600;
}

/* 控制区 */
.controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 80rpx;
  height: 240rpx;
  flex-shrink: 0;
}

/* 相册缩略图 */
.gallery-thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.25);
}

.gallery-img { width: 100%; height: 100%; }

.gallery-placeholder {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.1);
}

/* 快门 */
.shutter-outer {
  width: 144rpx;
  height: 144rpx;
  border-radius: 72rpx;
  border: 6rpx solid #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.shutter-inner {
  width: 124rpx;
  height: 124rpx;
  border-radius: 62rpx;
  background: #FFFFFF;
}

.shutter-outer:active .shutter-inner {
  transform: scale(0.92);
}

/* 翻转 */
.flip-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: rgba(255, 255, 255, 0.13);
  display: flex;
  align-items: center;
  justify-content: center;
}

.flip-icon { width: 44rpx; height: 44rpx; }

/* 底部指示器 */
.home-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48rpx;
  flex-shrink: 0;
  padding-bottom: env(safe-area-inset-bottom, 0);
}

.home-bar {
  width: 268rpx;
  height: 10rpx;
  border-radius: 5rpx;
  background: rgba(255, 255, 255, 0.38);
}
