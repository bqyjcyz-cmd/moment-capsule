<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height:{{statusBarHeight}}px;"></view>

  <!-- 顶部工具栏 -->
  <view class="top-bar">
    <image class="top-icon" src="/images/cam-close.svg" bindtap="onClose" />
    <image class="top-icon" src="/images/cam-flash.svg" bindtap="onFlashToggle" />
    <text class="hdr-label">HDR</text>
  </view>

  <!-- 取景框 -->
  <view class="viewfinder">
    <camera
      wx:if="{{authReady}}"
      class="camera-view"
      device-position="{{devicePosition}}"
      flash="{{flash}}"
      binderror="onCameraError"
    ></camera>
    <view wx:else class="camera-placeholder">
      <text class="camera-placeholder-text">正在获取相机权限...</text>
    </view>
  </view>

  <!-- 模式栏 -->
  <view class="mode-bar">
    <text class="mode-text {{mode === 'video' ? 'mode-active' : ''}}" data-mode="video" bindtap="onModeChange">视频</text>
    <text class="mode-text {{mode === 'photo' ? 'mode-active' : ''}}" data-mode="photo" bindtap="onModeChange">照片</text>
    <text class="mode-text {{mode === 'portrait' ? 'mode-active' : ''}}" data-mode="portrait" bindtap="onModeChange">人像</text>
  </view>

  <!-- 控制区 -->
  <view class="controls">
    <!-- 相册缩略图 -->
    <view class="gallery-thumb" bindtap="onGalleryTap">
      <image wx:if="{{lastPhoto}}" src="{{lastPhoto}}" mode="aspectFill" class="gallery-img" />
      <view wx:else class="gallery-placeholder"></view>
    </view>

    <!-- 快门按钮 -->
    <view class="shutter-outer" bindtap="onShutterTap">
      <view class="shutter-inner"></view>
    </view>

    <!-- 翻转相机 -->
    <view class="flip-btn" bindtap="onFlipTap">
      <image class="flip-icon" src="/images/cam-flip.svg" />
    </view>
  </view>

  <!-- 底部指示器 -->
  <view class="home-indicator">
    <view class="home-bar"></view>
  </view>
</view>
