.page {
  height: 100vh;
  background: #ECEAE2;
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
  height: 88rpx;
  border-bottom: 1rpx solid #D5D0C8;
  flex-shrink: 0;
}

.header-cancel { font-size: 28rpx; color: #A09A92; }
.header-title { font-size: 30rpx; font-weight: 500; color: #3A3632; }
.header-save { font-size: 28rpx; font-weight: 500; color: #C8C4BC; }
.header-save.active { color: #8BA676; }

/* 录音内容 */
.rec-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 80rpx;
}

.timer-label {
  font-size: 112rpx;
  font-weight: 300;
  color: #3A3632;
  letter-spacing: 4rpx;
  font-variant-numeric: tabular-nums;
}

/* 波形 */
.waveform-area {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 160rpx;
  width: 640rpx;
}

.wave-bar {
  width: 6rpx;
  border-radius: 4rpx;
  background: #D5D0C8;
  transition: height 0.15s ease;
}

.wave-bar-active {
  background: #8BA676;
  animation: waveAnim 0.8s ease-in-out infinite alternate;
}

@keyframes waveAnim {
  from { opacity: 0.6; }
  to { opacity: 1; }
}

/* 录音状态 */
.rec-status {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rec-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: #D47B7B;
  animation: blink 1s ease-in-out infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.rec-label { font-size: 26rpx; color: #A09A92; }

/* 底部控制 */
.bottom-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 96rpx;
  height: 280rpx;
  padding-bottom: 56rpx;
  flex-shrink: 0;
}

.ctrl-btn {
  width: 104rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background: #F6F4EE;
  border: 1rpx solid #D5D0C8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ctrl-btn.disabled { opacity: 0.35; pointer-events: none; }

.ctrl-icon { width: 44rpx; height: 44rpx; }

/* 录制/停止大按钮 */
.stop-btn {
  width: 136rpx;
  height: 136rpx;
  border-radius: 68rpx;
  background: #D47B7B;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stop-btn:active { transform: scale(0.95); }

.stop-square {
  width: 44rpx;
  height: 44rpx;
  border-radius: 8rpx;
  background: #FFFFFF;
}

.record-circle {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: #FFFFFF;
}

/* 录音完成确认区域 */
.confirm-area {
  flex-shrink: 0;
  padding: 24rpx 40rpx;
  background: #F6F4EE;
  border-top: 1rpx solid #D5D0C8;
}

.confirm-preview {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #ECEAE2;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.confirm-icon {
  width: 64rpx; height: 64rpx; border-radius: 32rpx;
  background: #8BA676; color: #FFFFFF; font-size: 28rpx;
  display: flex; align-items: center; justify-content: center;
}

.confirm-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.confirm-title { font-size: 28rpx; color: #3A3632; font-weight: 500; }
.confirm-duration { font-size: 22rpx; color: #A09A92; }

.confirm-play {
  width: 56rpx; height: 56rpx; border-radius: 28rpx;
  background: rgba(139, 166, 118, 0.12);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #8BA676;
}

.confirm-actions {
  display: flex; gap: 20rpx;
}

.confirm-btn-retry {
  flex: 1; height: 80rpx; border-radius: 40rpx;
  border: 2rpx solid #D5D0C8; background: transparent;
  display: flex; align-items: center; justify-content: center;
}

.confirm-btn-retry-text { font-size: 28rpx; color: #6B6560; }

.confirm-btn-use {
  flex: 2; height: 80rpx; border-radius: 40rpx;
  background: #8BA676;
  display: flex; align-items: center; justify-content: center;
}

.confirm-btn-use-text { font-size: 28rpx; color: #FFFFFF; font-weight: 500; }

.safe-bottom { padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); }
